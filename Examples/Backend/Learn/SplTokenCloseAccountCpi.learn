contract SolanaSplTokenCloseAccountCpi {
  state last_close_marker: u64

  solana account token_account writable
  solana account destination writable
  solana account authority readonly signer

  solana cpi token_close spl_token_close_account(token_account, destination, authority)

  entry close_account() {
    solana invoke token_close spl_token_close_account(token_account, destination, authority)
    last_close_marker = 1
  }
}
