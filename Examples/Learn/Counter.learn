contract Counter {
  state count: u64

  event CounterInitialized()
  event CounterIncremented(value: u64)

  entry initialize(initial: u64) {
    count = initial
    emit CounterInitialized()
  }

  entry increment(amount: u64) {
    let current: u64 = count
    let next: u64 = current + amount
    count = next
    emit CounterIncremented(value: next)
  }

  query get_count(): u64 {
    return count
  }
}
