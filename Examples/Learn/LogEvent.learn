contract SolanaLogEvent {
  state last_logged_amount: u64

  entry emit selector "08"(amount: u64) {
    emit AmountEvent(amount: amount)
    last_logged_amount = amount
  }

  entry log_state_pubkey selector "09"() {
    solana log pubkey log_state_account(last_logged_amount)
  }

  entry log_state_data selector "0a"() {
    solana log data log_amount_data(last_logged_amount) bytes 8
  }
}
