}

impl HashStorageProbeRef {
    #[contract_method]
    pub fn scalar_lifecycle() -> Hash {
        let c = HashStorageProbeRef::new(ContractMetadata::current());
        let first: Hash = [1, 2, 3, 4];
        let second: Hash = [5, 6, 7, 8];
        c.root = first;
        assert_eq(c.root.get(), first, "hash scalar reads first value");
        c.root = second;
        return c.root.get();
