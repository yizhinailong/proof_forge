{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-forge.dev/schemas/benchmark-result.v1.json",
  "title": "ProofForge benchmark result row",
  "description": "One row per (scenario, target, implementation). See docs/benchmarks.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schemaVersion",
    "scenario",
    "target",
    "implementation",
    "commit",
    "toolVersions",
    "behavior",
    "costs",
    "artifactBytes"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "proof-forge.benchmark-result.v1"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1,
      "pattern": "^bm-[a-z0-9-]+$"
    },
    "target": {
      "type": "string",
      "enum": [
        "evm",
        "solana-sbpf-asm",
        "wasm-near",
        "psy-dpn",
        "aleo-leo"
      ]
    },
    "implementation": {
      "type": "string",
      "enum": ["proofforge", "native"]
    },
    "commit": {
      "type": "string",
      "minLength": 1,
      "description": "Git commit SHA of the ProofForge tree used for the run"
    },
    "toolVersions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of tool name → version string (empty object allowed when tools unavailable)"
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "steps"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "return": {
                "description": "Scalar return as decimal string, null, or omitted",
                "type": ["string", "null"]
              },
              "storage": {
                "type": "object",
                "additionalProperties": {
                  "type": ["string", "number", "boolean", "null"]
                }
              },
              "events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "error": {
                "type": ["string", "null"]
              }
            }
          }
        }
      }
    },
    "costs": {
      "type": "object",
      "description": "Per-step cost maps; allowed keys depend on target (enforced by checker)",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": {
              "type": "number"
            }
          },
          {
            "type": "number"
          }
        ]
      }
    },
    "artifactBytes": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    }
  }
}
