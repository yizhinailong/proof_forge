[0.314, "o", "object \"Counter\" {\r\n  code {\r\n    switch shr(224, calldataload(0))\r\n    case 0x8129fc1c {\r\n      f_Counter_initialize()\r\n      return(0, 0)\r\n    }\r\n    case 0xd09de08a {\r\n      f_Counter_increment()\r\n      return(0, 0)\r\n    }\r\n    case 0x6d4ce63c {\r\n      let _r := f_Counter_get()\r\n      mstore(0, _r)\r\n      return(0, 32)\r\n    }\r\n    default {\r\n      revert(0, 0)\r\n    }\r\n    function f_Counter_initialize() {\r\n      sstore(0, 0)\r\n    }\r\n    function f_Counter_increment() {\r\n      let n := sload(0)\r\n      sstore(0, __pf_checked_add(n, 1))\r\n"]
[0.000, "o", "    }\r\n    function f_Counter_get() -> result {\r\n      result := sload(0)\r\n    }\r\n    function __pf_checked_add(a, b) -> r {\r\n"]
