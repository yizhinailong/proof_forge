[0.324, "o", "/-\r\nCopyright (c) 2026 DaviRain. All rights reserved.\r\nReleased under Apache 2.0 license as described in the file LICENSE.\r\n\r\nPortable Counter example for the unified EVM entry path.\r\n\r\nCompile:\r\n`lake env proof-forge build --target evm --root . -o build/evm/Counter.bin Examples/Evm/Contracts/Counter.lean`\r\n-/\r\nimport ProofForge.Contract.Source\r\n\r\nnamespace Counter\r\n\r\nopen ProofForge.Contract.Source\r\n\r\ncontract_source Counter do\r\n  constructor_param initial : .u64;\r\n\r\n  state count : .u64\r\n\r\n  entry «initialize» do\r\n    count := u64 0;\r\n\r\n  entry increment do\r\n    let n : .u64 := count;\r\n    count := n +! u64 1;\r\n\r\n  query get returns(.u64) do\r\n    return count;\r\n\r\nend Counter\r\n"]
[0.000, "o", "\r\n"]
[1.009, "o", "Key elements:\r\n  • contract_source — declarative contract DSL\r\n"]
[0.000, "o", "  • state — on-chain storage declarations\r\n  • entry — state-modifying entrypoints\r\n"]
[0.000, "o", "  • query — read-only entrypoints\r\n\r\n"]
[1.510, "o", "Now let's write a new contract — a SimpleStorage with access control:\r\n\r\n"]
[1.011, "o", "\r\n"]
