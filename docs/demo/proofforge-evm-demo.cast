[0.278, "o", "╔══════════════════════════════════════════════════════════════╗\r\n║          ProofForge — EVM Complete Workflow Demo            ║\r\n║   Author → Compile → Deploy → Test                           ║\r\n"]
[0.000, "o", "╚══════════════════════════════════════════════════════════════╝\r\n\r\nProofForge lowers Lean smart-contract sources to portable IR and\r\ntarget artifacts. The EVM backend produces Yul → solc → bytecode,\r\nwith Foundry/Anvil runtime validation.\r\n\r\n"]
[1.508, "o", "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n  Part 1/4: Contract Authoring\r\n"]
[0.000, "o", "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n\r\n"]
[1.010, "o", "Contracts are authored in Lean 4 using ProofForge.Contract.Source.\r\nLet's look at the Counter example:\r\n\r\n"]
[1.010, "o", "\r\n"]
