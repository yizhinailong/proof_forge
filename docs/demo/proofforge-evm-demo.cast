[0.318, "o", "/-\r\nCopyright (c) 2026 DaviRain. All rights reserved.\r\nReleased under Apache 2.0 license as described in the file LICENSE.\r\n\r\nPortable VerifiedVault for the unified EVM entry path. Source-level financial\r\nproofs remain in `VerifiedVault.Spec`; codegen uses portable IR only.\r\n-/\r\n"]
[0.000, "o", "import ProofForge.Contract.Source\r\nimport ProofForge.Contract.Stdlib.ReentrancyGuard\r\n\r\nnamespace VerifiedVault\r\n\r\nopen ProofForge.Contract.Source\r\nopen ProofForge.Contract.Stdlib.ReentrancyGuard\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "namespace Spec\r\n\r\nstructure State where\r\n  reserves : Nat\r\n"]
[0.000, "o", "  shares   : Nat\r\n"]
[0.000, "o", "\r\ndef solvent (s : State) : Prop := s.reserves = s.shares\r\n\r\ndef empty : State := { reserves := 0, shares := 0 }\r\n\r\ndef deposit? (s : State) (amount : Nat) : Option State :=\r\n  some { reserves := s.reserves + amount, shares := s.shares + amount }\r\n\r\n"]
[0.000, "o", "def withdraw? (s : State) (amount : Nat) : Option State :=\r\n"]
[0.000, "o", "  if amount ≤ s.reserves ∧ amount ≤ s.shares then\r\n"]
[0.000, "o", "    some { reserves := s.reserves - amount, shares := s.shares - amount }\r\n  else none\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "def canWithdraw (s : State) (amount : Nat) : Bool :=\r\n"]
[0.000, "o", "  amount ≤ s.reserves ∧ amount ≤ s.shares\r\n\r\ntheorem empty_solvent : solvent empty := by rfl\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "theorem deposit_preserves_solvent {s next : State} {amount : Nat}\r\n    (h : solvent s) (hn : deposit? s amount = some next) : solvent next := by\r\n"]
[0.001, "o", "\r\n"]
[1.005, "o", "VerifiedVault demonstrates proof-carrying contract authoring with\r\nassertions, context reads (caller, address, block number), and\r\n"]
[0.000, "o", "compound storage assignment.\r\n"]
[0.000, "o", "\r\n"]
[2.009, "o", "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n  Part 2/4: Compilation (Lean → IR → Yul → Bytecode)\r\n"]
