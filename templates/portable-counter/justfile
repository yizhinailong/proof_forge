# Multi-target build recipes for the portable Counter starter.
set shell := ["bash", "-eu", "-o", "pipefail", "-c"]

proof_forge := env_var_or_default('PROOF_FORGE_BIN', 'lake env proof-forge')
source := "Counter.lean"

build-cli:
    lake build proofForge:proof-forge

check-source:
    lake build Counter

build-evm: build-cli check-source
    mkdir -p build/evm
    {{proof_forge}} build --target evm --root . \
      -o build/evm/Counter.bin \
      --yul-output build/evm/Counter.yul \
      --artifact-output build/evm/Counter.proof-forge-artifact.json \
      {{source}}

forge-test: build-evm
    (cd foundry && forge test -vv)

forge-script: build-evm
    (cd foundry && forge script script/DeployCounter.s.sol:DeployCounter -vv)

forge-all: forge-test forge-script

deploy-evm-anvil: build-evm
    {{proof_forge}} deploy --target evm --root . \
      --deploy-manifest build/evm/Counter.proof-forge-deploy.json \
      --evm-chain-profile anvil-local \
      --start-anvil \
      --output build/evm/Counter.proof-forge-deploy-run.json

deploy-evm-plan: build-evm
    {{proof_forge}} deploy --target evm --root . \
      --deploy-manifest build/evm/Counter.proof-forge-deploy.json \
      --evm-chain-profile robinhood-chain-testnet \
      --plan-only \
      --output build/evm/Counter.proof-forge-deploy-plan.json

build-solana: build-cli check-source
    mkdir -p build/solana
    {{proof_forge}} build --target solana-sbpf-asm --root . \
      -o build/solana/Counter.s \
      --artifact-output build/solana/Counter.solana-artifact.json \
      {{source}}

build-near: build-cli check-source
    mkdir -p build/near
    {{proof_forge}} build --target wasm-near --root . \
      -o build/near \
      --artifact-output build/near/Counter.near-artifact.json \
      {{source}}

build-all: build-evm build-solana build-near
